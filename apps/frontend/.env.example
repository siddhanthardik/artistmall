# ==========================================
# THE ARTIST MALL - FRONTEND ENV TEMPLATE
# ==========================================
# Variables prefixed with VITE_ are exposed to the client.
# NEVER put sensitive secrets (like DB passwords) here.

# 1. API Configuration
# Point this to your production backend URL
VITE_API_BASE_URL=https://api.theartistmall.com/api/v1

# 2. Media / CDN Configuration
VITE_IMAGE_CDN_URL=https://res.cloudinary.com/your_cloud_name/image/upload

# 3. Analytics & Monitoring (Optional)
VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
VITE_LOGROCKET_ID=your-org/artist-mall

# 4. Environment Identifier
VITE_APP_ENV=production
