# ==========================================
# THE ARTIST MALL - BACKEND ENV TEMPLATE
# ==========================================
# DO NOT COMMIT ACTUAL SECRETS TO GIT
# COPY THIS FILE TO .env FOR LOCAL DEV

# 1. Server Configuration
PORT=5000
NODE_ENV=production
# Used for CORS - must exactly match frontend production URL
FRONTEND_URL=https://www.theartistmall.com 

# 2. Database
# Use MongoDB Atlas string for production
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/artistmall?retryWrites=true&w=majority

# 3. Security & Authentication
# Generate strong 64-character hex strings for these
JWT_ACCESS_SECRET=generate_strong_secret_for_access_token_here
JWT_REFRESH_SECRET=generate_strong_secret_for_refresh_token_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# 4. Redis Caching & Queue Layer
REDIS_URI=redis://default:<password>@redis-cluster.com:6379
REDIS_CACHE_TTL=3600

# 5. Rate Limiting (Security)
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# 6. Media Storage (Cloudinary/S3)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# 7. Email Provider (SendGrid/AWS SES)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_smtp_password
FROM_EMAIL=noreply@theartistmall.com

# 8. Admin Config
# Receive critical system alerts here
ADMIN_ALERT_EMAIL=founders@theartistmall.com
